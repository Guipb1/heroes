// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Nomeei os campos em snake_case de propósito: o contrato da API exige essas
// chaves exatas na resposta JSON, então o objeto que o Prisma devolve já
// nasce no formato certo, sem precisar de um mapeamento camelCase -> snake_case.
model Hero {
  id            String   @id @default(uuid()) @db.VarChar(36)
  name          String
  nickname      String
  date_of_birth DateTime
  universe      String
  main_power    String
  avatar_url    String   @db.VarChar(500)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("heroes")
}
